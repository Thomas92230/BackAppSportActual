# Configuration des clés API - Copier ce fichier en .env et ajouter vos vraies clés
# IMPORTANT: Ne jamais ajouter .env au contrôle Git !

# NewsAPI - Clé principale pour les articles sportifs
NEWSAPI_KEY=votre_clé_newsapi_ici

# Guardian API - Pour les articles sportifs internationaux  
GUARDIAN_API_KEY=cf1811d2-3e59-4c13-9f9e-318313da2c7f

# World News API - Pour les articles sportifs mondiaux
WORLDNEWS_API_KEY=97b747ae2fd64bc4812d0ec8b1f8bc16

# API-Sports via RapidAPI - Optionnel pour les données de match
RAPIDAPI_KEY=votre_clé_rapidapi_ici

# Configuration AWS - Optionnel
AWS_REGION=us-east-1
AWS_ACCESS_KEY=votre_clé_aws_access
AWS_SECRET_KEY=votre_clé_aws_secret
AWS_SNS_TOPIC_ARN=votre_sns_topic_arn

# JWT Secret - Pour l'authentification
JWT_SECRET=votre_secret_jwt_très_long_et_sécurisé

# Configuration de la base de données (Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=actu_sport_db
DB_USER=actu_sport_user
DB_PASSWORD=votre_mot_de_passe_db

# Configuration Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
