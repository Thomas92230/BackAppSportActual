# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sportactual
SPRING_DATASOURCE_USERNAME=sportuser
SPRING_DATASOURCE_PASSWORD=sportpass

# Redis Configuration
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# External APIs
API_SPORTS_KEY=your_api_sports_key_here
ESPN_API_KEY=your_espn_api_key_here

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:sport-notifications

# JWT Configuration
JWT_SECRET=mySecretKey123456789012345678901234567890
JWT_EXPIRATION=86400

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev
